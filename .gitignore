# =============================================================================
# .gitignore — 人工智能训练师五级练习与考试系统
# 原则：密钥/私密信息绝不入库；开发工具缓存/IDE 配置目录不入库。
# 注意：.coze 是部署配置，必须入库，不可忽略。
# =============================================================================

# -----------------------------------------------------------------------------
# 依赖
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*

# -----------------------------------------------------------------------------
# 构建产物
# -----------------------------------------------------------------------------
.next/
dist/
build/
out/
.nuxt/
.turbo/
.vercel/
.rsbuild/
.parcel-cache/

# -----------------------------------------------------------------------------
# 环境变量 & 密钥（绝不入库）
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.keystore

# -----------------------------------------------------------------------------
# TypeScript 增量编译缓存
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# 测试覆盖率
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# 日志
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
output.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.coze-logs/

# -----------------------------------------------------------------------------
# 编辑器 / IDE 配置目录
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*~
.history/

# -----------------------------------------------------------------------------
# 开发工具索引 / 缓存目录
# -----------------------------------------------------------------------------
.codegraph/
.cache/
.eslintcache
.stylelintcache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
__pycache__/
*.pyc
.venv/
vendor/
*.egg-info/

# -----------------------------------------------------------------------------
# 进程 / 运行时数据
# -----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
node-compile-cache/

# -----------------------------------------------------------------------------
# 预览 / 临时文件（沙箱环境）
# -----------------------------------------------------------------------------
.preview
.cozeproj/reduction
*.tmp
*.temp
.tmp/
.temp/

# -----------------------------------------------------------------------------
# 操作系统文件
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 二进制 / 媒体文件（通过源码或脚本生成，不入库）
# -----------------------------------------------------------------------------
# 视频
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm
*.m4v
*.mpeg
*.mpg
*.3gp
*.f4v
*.rmvb
*.vob
# 归档
*.iso
*.dmg
*.rar
*.zip
*.gz
*.tar
*.tgz
# 文档二进制（源码 Markdown 入库，生成的 PDF/Word 不入库）
*.pdf
*.docx
*.doc
*.xlsx
*.xls
*.ppt
*.pptx
